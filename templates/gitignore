# safe-start starter .gitignore — reduces accidental Git exposure.
# Ignoring a file does not stop an agent or local process from reading it.
# Never place real or re-identifiable patient data in this workspace.

# Secrets & credentials
.env
.env.*
!.env.example
!.env.sample
!.env.template
*.key
*.pem
*.p12
*.pfx
credentials.json
secrets.*
.secrets/

# Legacy defensive exclusion only. Never put PHI here: ignored != inaccessible.
/private/

# OS & editor junk
.DS_Store
Thumbs.db
*.swp

# Dependencies & build output
node_modules/
dist/
build/
__pycache__/
.venv/
venv/
